{
    "name": "devdojo/foundation",
    "description": "The DevDojo Foundation — auth, billing, blog, changelog, notifications and accounts, bundled.",
    "keywords": ["devdojo", "foundation", "laravel", "saas"],
    "homepage": "https://github.com/thedevdojo/foundation",
    "license": "MIT",
    "type": "library",
    "version": "0.0.1",
    "authors": [
        {
            "name": "Tony Lea",
            "email": "tony@devdojo.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "devdojo/auth": "*",
        "devdojo/accounts": "*",
        "devdojo/billing": "*",
        "devdojo/blog": "*",
        "devdojo/changelog": "*",
        "devdojo/components": "*",
        "devdojo/notifications": "*",
        "devdojo/teams": "*"
    },
    "autoload": {
        "psr-4": {
            "Devdojo\\Foundation\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Devdojo\\Foundation\\FoundationServiceProvider"
            ]
        }
    }
}
